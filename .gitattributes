# Global default to let Git detect or normalize line endings
* text=auto

# Declare files that will always have LF line endings on source control
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Denote files that are truly binary and must never be modified by line encoding normalization
*.jar binary
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.keystore binary
*.jks binary
*.so binary
*.aar binary
